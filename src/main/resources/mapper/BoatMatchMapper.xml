<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tencent.wxcloudrun.dao.BoatMatchMapper">

    <resultMap id="BoatMatchResultMap" type="com.tencent.wxcloudrun.model.BoatMatch">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="messageId" column="message_id"/>
        <result property="matchType" column="match_type"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.tencent.wxcloudrun.model.BoatMatch">
        INSERT INTO boat_matches (
            id, user_id, message_id, match_type, created_at
        ) VALUES (
            #{id}, #{userId}, #{messageId}, #{matchType}, #{createdAt}
        )
    </insert>

    <select id="findByUserIdAndMessageIdAndMatchType" resultMap="BoatMatchResultMap">
        SELECT *
        FROM boat_matches
        WHERE user_id = #{userId}
          AND message_id = #{messageId}
          AND match_type = #{matchType}
        LIMIT 1
    </select>

</mapper>

