/* pages/detail/index.wxss */

.detail-page {
  min-height: 100vh;
  background: #FDF8F0;
  padding-bottom: 140rpx;
  transition: background 0.3s ease;
}

/* 娌夋蹈妯″紡 */
.detail-page.immersive {
  background: #F5F3F0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* 璇楄瘝姝ｆ枃鍖?*/
.poem-section {
  margin: 36rpx 24rpx 24rpx;
  padding: 52rpx 40rpx 48rpx;
  text-align: center;
  position: relative;
  background: linear-gradient(180deg, rgba(255,255,255,0.88) 0%, rgba(253,248,240,0.96) 100%);
  border: 1rpx solid rgba(90, 106, 95, 0.08);
  border-radius: 36rpx;
  box-shadow: 0 12rpx 30rpx rgba(58, 74, 63, 0.08);
}
.detail-page.immersive .poem-section {
  margin: 0 24rpx;
  padding: 96rpx 40rpx 96rpx;
  background: rgba(255,255,255,0.62);
}

.poem-eyebrow {
  display: inline-block;
  margin-bottom: 16rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(58, 74, 63, 0.08);
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: #5A6A5F;
}

/* 绻佺畝鍒囨崲鎸夐挳 */
.chinese-toggle {
  position: absolute;
  right: 28rpx;
  top: 28rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(58, 74, 63, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}
.chinese-toggle:active {
  background: rgba(58, 74, 63, 0.15);
}
.toggle-text {
  font-size: 28rpx;
  color: #3A4A3F;
  font-weight: 500;
}

.poem-title {
  display: block;
  font-size: 54rpx;
  font-weight: 600;
  color: #3A4A3F;
  letter-spacing: 3rpx;
  margin-bottom: 12rpx;
}

.poem-meta {
  display: block;
  font-size: 28rpx;
  color: #7A8A7F;
  margin-bottom: 30rpx;
  letter-spacing: 2rpx;
}

.poem-divider {
  width: 120rpx;
  height: 1rpx;
  margin: 0 auto 20rpx;
  background: linear-gradient(90deg, rgba(212, 184, 150, 0) 0%, rgba(212, 184, 150, 0.8) 50%, rgba(212, 184, 150, 0) 100%);
}

.poem-tip {
  display: block;
  margin-bottom: 16rpx;
  font-size: 20rpx;
  color: #9AA59F;
  letter-spacing: 2rpx;
}

.poem-body {
  margin-top: 10rpx;
}

.poem-line {
  display: block;
  font-size: 34rpx;
  color: #3A4A3F;
  line-height: 1.92;
  letter-spacing: 2rpx;
}

.sentence-favorited {
  background: rgba(212, 184, 150, 0.22);
  border-radius: 14rpx;
  padding: 6rpx 10rpx;
  margin: 4rpx -10rpx;
}

.section-kicker {
  display: block;
  margin: 0 0 16rpx;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: #9AA59F;
  text-transform: uppercase;
}

.tags-section {
  padding: 24rpx 48rpx;
}
.tags-scroll {
  white-space: nowrap;
}
.tags-inner {
  display: inline-flex;
  gap: 12rpx;
}
.tag-capsule:active {
  opacity: 0.6;
}

.author-section {
  margin: 0 24rpx 16rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #FBF8F1 100%);
  border: 1rpx solid rgba(90, 106, 95, 0.08);
  border-radius: 24rpx;
  padding: 26rpx 30rpx 28rpx;
  box-shadow: 0 6rpx 22rpx rgba(58, 74, 63, 0.055);
}
.author-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.author-name {
  font-size: 30rpx;
  color: #3A4A3F;
  font-weight: 500;
}
.author-arrow {
  font-size: 24rpx;
  color: #D4B896;
}
.author-bio {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}
.author-bio.expanded {
  max-height: 600rpx;
  overflow-y: auto;
}
.author-bio-text {
  display: block;
  font-size: 26rpx;
  color: #5A6A5F;
  line-height: 1.8;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #E8E4DF;
}

.tab-section {
  padding: 0 24rpx 26rpx;
}

.tab-bar {
  display: flex;
  padding: 8rpx;
  background: rgba(58, 74, 63, 0.05);
  border-radius: 20rpx;
  margin-bottom: 2rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0 14rpx;
  font-size: 28rpx;
  color: #9AA59F;
  position: relative;
  transition: color 0.2s ease;
  border-radius: 16rpx;
}

.tab-item.active {
  color: #3A4A3F;
  font-weight: 500;
  background: #FFFFFF;
  box-shadow: 0 4rpx 14rpx rgba(58, 74, 63, 0.08);
}

.tab-item.active::after {
  display: none;
}

.tab-content {
  margin: 16rpx 0 0;
}

.tab-panel {
  background: linear-gradient(180deg, #FFFFFF 0%, #FBF8F1 100%);
  border-radius: 24rpx;
  padding: 34rpx 32rpx;
  border: 1rpx solid rgba(90, 106, 95, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(58, 74, 63, 0.05);
}

.tab-text {
  font-size: 29rpx;
  color: #5A6A5F;
  line-height: 1.9;
  letter-spacing: 1rpx;
}

.bottom-bar {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  bottom: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  padding: 10rpx;
  padding-bottom: calc(10rpx + env(safe-area-inset-bottom));
  background: rgba(253, 248, 240, 0.74);
  backdrop-filter: blur(28px);
  gap: 8rpx;
  border: 1rpx solid rgba(90, 106, 95, 0.06);
  border-radius: 34rpx;
  box-shadow: 0 16rpx 36rpx rgba(90, 106, 95, 0.09);
  z-index: 20;
}

.bottom-btn {
  width: 100%;
  min-width: 0;
  height: 118rpx;
  box-sizing: border-box;
  text-align: center;
  padding: 0;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #4B5A4F 0%, #39463C 100%);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.10), 0 7rpx 14rpx rgba(57, 70, 60, 0.10);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.favorite-btn {
  background: linear-gradient(180deg, #DCC29D 0%, #C9A26E 100%);
}

.favorite-btn.active {
  background: linear-gradient(180deg, #C8A06F 0%, #B8834D 100%);
}

.generate-btn {
  background: linear-gradient(180deg, #EAE6DD 0%, #DAD6CC 100%);
}

.generate-btn .btn-main,
.generate-btn .btn-sub {
  color: #3E4A41;
}

.rain-btn {
  background: linear-gradient(180deg, #7E8D82 0%, #5E6F64 100%);
}

.rain-btn.active {
  background: linear-gradient(180deg, #6D7B70 0%, #4D5C53 100%);
}

.favorite-btn .btn-main,
.favorite-btn .btn-sub {
  color: #FFF9F1;
}

.share-btn {
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, #445347 0%, #314036 100%) !important;
  border: none;
  line-height: normal;
  margin: 0;
  width: 100%;
}
.share-trigger {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  z-index: 2;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
}
.share-trigger::after {
  border: none;
}
.share-btn,
.share-btn::before,
.share-btn::after {
  box-sizing: border-box;
}

.share-btn .btn-main,
.share-btn .btn-sub {
  color: #FDF8F0 !important;
}

.btn-main {
  display: block;
  font-size: 25rpx;
  line-height: 1.2;
  font-weight: 600;
  color: #FDF8F0;
}

.btn-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 15rpx;
  line-height: 1.2;
  color: rgba(253, 248, 240, 0.78);
}


/* 鎷奸煶寮圭獥 */
.pinyin-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pinyin-modal {
  background: #FDF8F0;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  max-width: 88%;
  max-height: 70vh;
  overflow-y: auto;
  animation: fadeInModal 0.2s ease;
}
@keyframes fadeInModal {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}
.pinyin-loading {
  text-align: center;
  padding: 40rpx 0;
}
.pinyin-loading text {
  font-size: 28rpx;
  color: #7A8A7F;
}
.pinyin-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 4rpx;
  margin-bottom: 32rpx;
}
.pinyin-char-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 52rpx;
}
.pinyin-text {
  font-size: 20rpx;
  color: #D4B896;
  height: 36rpx;
  line-height: 36rpx;
}
.pinyin-placeholder {
  height: 36rpx;
}
.pinyin-char {
  font-size: 40rpx;
  color: #3A4A3F;
  line-height: 1.6;
}
.pinyin-actions {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  margin-top: 20rpx;
  flex-wrap: wrap;
}
.pinyin-copy-btn {
  background: #3A4A3F;
  border-radius: 32rpx;
  padding: 16rpx 48rpx;
}
.pinyin-copy-btn text {
  font-size: 26rpx;
  color: #FDF8F0;
}
.pinyin-close-btn {
  background: #FFFFFF;
  border: 2rpx solid #E8E4DF;
  border-radius: 32rpx;
  padding: 16rpx 48rpx;
}
.pinyin-fav-btn {
  background: #D4B896;
  border-radius: 32rpx;
  padding: 16rpx 40rpx;
}
.pinyin-fav-btn text {
  font-size: 26rpx;
  color: #FFFFFF;
}
.pinyin-fav-btn.excerpt-btn {
  background: #7A8A7F;
}
.pinyin-close-btn text {
  font-size: 26rpx;
  color: #3A4A3F;
}
.pinyin-copy-btn:active, .pinyin-close-btn:active, .pinyin-fav-btn:active {
  opacity: 0.7;
}

.rhyme-btn {
  background: #A07C4A;
}

.excerpt-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.excerpt-modal {
  width: 100%;
  background: #FDF8F0;
  border-radius: 24rpx;
  padding: 36rpx;
  box-sizing: border-box;
}

.excerpt-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #3A4A3F;
}

.excerpt-sentence {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #5A6A5F;
}

.excerpt-note-input {
  margin-top: 24rpx;
  min-height: 180rpx;
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  border: 1rpx solid #E8E4DF;
  font-size: 26rpx;
  color: #3A4A3F;
}

.excerpt-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.excerpt-cancel,
.excerpt-save {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 999rpx;
}

.excerpt-cancel {
  background: #FFFFFF;
  border: 1rpx solid #E8E4DF;
}

.excerpt-save {
  background: #3A4A3F;
}

.excerpt-cancel text {
  color: #3A4A3F;
  font-size: 26rpx;
}

.excerpt-save text {
  color: #FFFFFF;
  font-size: 26rpx;
}

.rhyme-card {
  margin-top: 20rpx;
}

.rhyme-line,
.rhyme-note {
  display: block;
  font-size: 26rpx;
  line-height: 1.8;
  color: #5A6A5F;
}

.rhyme-note {
  color: #7A8A7F;
  margin-top: 8rpx;
}

.rain-panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 28rpx;
  z-index: 20;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.rain-switch-card {
  width: 100%;
  padding: 20rpx 28rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, rgba(58, 74, 63, 0.92) 0%, rgba(45, 58, 49, 0.94) 100%);
  border: 1rpx solid rgba(253, 248, 240, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 14rpx 36rpx rgba(58, 74, 63, 0.2);
}

.rain-switch-card.active {
  background: linear-gradient(180deg, rgba(90, 106, 95, 0.96) 0%, rgba(69, 82, 74, 0.98) 100%);
}

.rain-switch-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
}

.rain-title {
  font-size: 28rpx;
  color: #FDF8F0;
  letter-spacing: 3rpx;
}

.rain-subtitle {
  font-size: 21rpx;
  color: rgba(253, 248, 240, 0.78);
}

.rain-switch {
  transform: scale(0.9);
  transform-origin: center right;
}

.rain-switch-tip {
  font-size: 20rpx;
  color: rgba(90, 106, 95, 0.66);
  letter-spacing: 2rpx;
  padding: 0 12rpx;
}

.rain-source-scroll {
  max-width: 100%;
  white-space: nowrap;
}

.rain-source-list {
  display: inline-flex;
  gap: 14rpx;
}

.rain-source-chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(58, 74, 63, 0.08);
}

.rain-source-chip text {
  font-size: 22rpx;
  color: #5A6A5F;
}

.rain-source-chip.active {
  background: #D4B896;
  border-color: #D4B896;
}

.rain-source-chip.active text {
  color: #FFFFFF;
}

.immersive-hint {
  position: fixed;
  bottom: 142rpx;
  left: 0;
  right: 0;
  text-align: center;
  animation: fadeInHint 1s ease 1s both;
}

.immersive-hint text {
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(253, 248, 240, 0.72);
  border: 1rpx solid rgba(90, 106, 95, 0.07);
  box-shadow: 0 6rpx 16rpx rgba(58, 74, 63, 0.04);
  font-size: 22rpx;
  color: #9AA59F;
}

@keyframes fadeInHint {
  from { opacity: 0; }
  to { opacity: 0.55; }
}
