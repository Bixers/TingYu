/* pages/detail/index.wxss */

.detail-page {
  min-height: 100vh;
  background: #FDF8F0;
  padding-bottom: 140rpx;
  transition: background 0.3s ease;
}

/* 沉浸模式 */
.detail-page.immersive {
  background: #F5F3F0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* 诗词正文区 */
.poem-section {
  padding: 80rpx 48rpx 40rpx;
  text-align: center;
  position: relative;
}
.detail-page.immersive .poem-section {
  padding: 120rpx 48rpx;
}

/* 繁简切换按钮 */
.chinese-toggle {
  position: absolute;
  right: 48rpx;
  top: 80rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(58, 74, 63, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}
.chinese-toggle:active {
  background: rgba(58, 74, 63, 0.15);
}
.toggle-text {
  font-size: 28rpx;
  color: #3A4A3F;
  font-weight: 500;
}

.poem-title {
  display: block;
  font-size: 52rpx;
  font-weight: 600;
  color: #3A4A3F;
  letter-spacing: 6rpx;
  margin-bottom: 20rpx;
}

.poem-meta {
  display: block;
  font-size: 28rpx;
  color: #7A8A7F;
  margin-bottom: 48rpx;
  letter-spacing: 2rpx;
}

.poem-body {
  margin-top: 40rpx;
}

.poem-line {
  display: block;
  font-size: 38rpx;
  color: #3A4A3F;
  line-height: 2.2;
  letter-spacing: 4rpx;
}

.sentence-favorited {
  background: rgba(212, 184, 150, 0.22);
  border-radius: 14rpx;
  padding: 6rpx 10rpx;
  margin: 4rpx -10rpx;
}

/* 标签条 */
.tags-section {
  padding: 24rpx 48rpx;
}
.tags-scroll {
  white-space: nowrap;
}
.tags-inner {
  display: inline-flex;
  gap: 12rpx;
}
.tag-capsule:active {
  opacity: 0.6;
}

/* 作者介绍 */
.author-section {
  margin: 0 48rpx 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(58, 74, 63, 0.06);
}
.author-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.author-name {
  font-size: 28rpx;
  color: #3A4A3F;
  font-weight: 500;
}
.author-arrow {
  font-size: 24rpx;
  color: #D4B896;
}
.author-bio {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}
.author-bio.expanded {
  max-height: 600rpx;
  overflow-y: auto;
}
.author-bio-text {
  display: block;
  font-size: 26rpx;
  color: #5A6A5F;
  line-height: 1.8;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #E8E4DF;
}

/* Tab切换条 */
.tab-section {
  padding: 0 32rpx 24rpx;
}

.tab-bar {
  display: flex;
  border-bottom: 2rpx solid #E8E4DF;
  margin-bottom: 0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #9AA59F;
  position: relative;
  transition: color 0.2s ease;
}

.tab-item.active {
  color: #3A4A3F;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #D4B896;
  border-radius: 2rpx;
}

/* Tab内容 */
.tab-content {
  margin: 24rpx 0;
}

.tab-panel {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(58, 74, 63, 0.06);
}

.tab-text {
  font-size: 30rpx;
  color: #5A6A5F;
  line-height: 1.8;
  letter-spacing: 1rpx;
}

/* 注释列表 */
.annotation-item {
  display: flex;
  margin-bottom: 20rpx;
  line-height: 1.6;
}
.annotation-item:last-child {
  margin-bottom: 0;
}
.annotation-word {
  font-size: 30rpx;
  color: #D4B896;
  font-weight: 500;
  white-space: nowrap;
  margin-right: 16rpx;
}
.annotation-meaning {
  font-size: 28rpx;
  color: #5A6A5F;
  flex: 1;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(253, 248, 240, 0.95);
  backdrop-filter: blur(10px);
  gap: 24rpx;
}

.bottom-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 40rpx;
  background: #3A4A3F;
}

.favorite-btn {
  background: #D4B896;
}

.favorite-btn.active {
  background: #C69B6D;
}

.voice-btn {
  background: #7A8A7F;
}

.voice-btn.active {
  background: #5A6A5F;
}

.voice-btn.disabled {
  background: #A7B0AA;
}

.bottom-btn .btn-label {
  font-size: 28rpx;
  color: #FDF8F0;
}

.share-btn {
  background: #FFFFFF !important;
  border: 2rpx solid #E8E4DF;
  line-height: normal;
  margin: 0;
}
.share-btn::after {
  border: none;
}

.share-btn .btn-label {
  color: #3A4A3F !important;
}

.favorite-btn .btn-label {
  color: #FFFFFF;
}

.voice-btn .btn-label {
  color: #FFFFFF;
}

/* 沉浸模式退出提示 */
.immersive-hint {
  position: fixed;
  bottom: 80rpx;
  left: 0;
  right: 0;
  text-align: center;
  animation: fadeInHint 1s ease 1s both;
}

.immersive-hint text {
  font-size: 24rpx;
  color: #9AA59F;
}

@keyframes fadeInHint {
  from { opacity: 0; }
  to { opacity: 0.6; }
}

/* 拼音弹窗 */
.pinyin-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pinyin-modal {
  background: #FDF8F0;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  max-width: 88%;
  max-height: 70vh;
  overflow-y: auto;
  animation: fadeInModal 0.2s ease;
}
@keyframes fadeInModal {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}
.pinyin-loading {
  text-align: center;
  padding: 40rpx 0;
}
.pinyin-loading text {
  font-size: 28rpx;
  color: #7A8A7F;
}
.pinyin-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 4rpx;
  margin-bottom: 32rpx;
}
.pinyin-char-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 52rpx;
}
.pinyin-text {
  font-size: 20rpx;
  color: #D4B896;
  height: 36rpx;
  line-height: 36rpx;
}
.pinyin-placeholder {
  height: 36rpx;
}
.pinyin-char {
  font-size: 40rpx;
  color: #3A4A3F;
  line-height: 1.6;
}
.pinyin-actions {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  margin-top: 20rpx;
  flex-wrap: wrap;
}
.pinyin-copy-btn {
  background: #3A4A3F;
  border-radius: 32rpx;
  padding: 16rpx 48rpx;
}
.pinyin-copy-btn text {
  font-size: 26rpx;
  color: #FDF8F0;
}
.pinyin-close-btn {
  background: #FFFFFF;
  border: 2rpx solid #E8E4DF;
  border-radius: 32rpx;
  padding: 16rpx 48rpx;
}
.pinyin-fav-btn {
  background: #D4B896;
  border-radius: 32rpx;
  padding: 16rpx 40rpx;
}
.pinyin-fav-btn text {
  font-size: 26rpx;
  color: #FFFFFF;
}
.pinyin-fav-btn.excerpt-btn {
  background: #7A8A7F;
}
.pinyin-close-btn text {
  font-size: 26rpx;
  color: #3A4A3F;
}
.pinyin-copy-btn:active, .pinyin-close-btn:active, .pinyin-fav-btn:active {
  opacity: 0.7;
}

.rhyme-btn {
  background: #A07C4A;
}

.excerpt-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.excerpt-modal {
  width: 100%;
  background: #FDF8F0;
  border-radius: 24rpx;
  padding: 36rpx;
  box-sizing: border-box;
}

.excerpt-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #3A4A3F;
}

.excerpt-sentence {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #5A6A5F;
}

.excerpt-note-input {
  margin-top: 24rpx;
  min-height: 180rpx;
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  border: 1rpx solid #E8E4DF;
  font-size: 26rpx;
  color: #3A4A3F;
}

.excerpt-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.excerpt-cancel,
.excerpt-save {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 999rpx;
}

.excerpt-cancel {
  background: #FFFFFF;
  border: 1rpx solid #E8E4DF;
}

.excerpt-save {
  background: #3A4A3F;
}

.excerpt-cancel text {
  color: #3A4A3F;
  font-size: 26rpx;
}

.excerpt-save text {
  color: #FFFFFF;
  font-size: 26rpx;
}

.rhyme-card {
  margin-top: 20rpx;
}

.rhyme-line,
.rhyme-note {
  display: block;
  font-size: 26rpx;
  line-height: 1.8;
  color: #5A6A5F;
}

.rhyme-note {
  color: #7A8A7F;
  margin-top: 8rpx;
}

.rain-panel {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 36rpx;
  z-index: 20;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.rain-switch-card {
  width: 100%;
  padding: 18rpx 30rpx;
  border-radius: 28rpx;
  background: rgba(58, 74, 63, 0.9);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 10rpx 30rpx rgba(58, 74, 63, 0.18);
}

.rain-switch-card.active {
  background: rgba(90, 106, 95, 0.96);
}

.rain-switch-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
}

.rain-title {
  font-size: 30rpx;
  color: #FDF8F0;
  letter-spacing: 4rpx;
}

.rain-subtitle {
  font-size: 22rpx;
  color: rgba(253, 248, 240, 0.78);
}

.rain-switch {
  transform: scale(0.9);
  transform-origin: center right;
}

.rain-switch-tip {
  font-size: 20rpx;
  color: rgba(90, 106, 95, 0.72);
  letter-spacing: 2rpx;
}

.rain-source-scroll {
  max-width: 100%;
  white-space: nowrap;
}

.rain-source-list {
  display: inline-flex;
  gap: 14rpx;
}

.rain-source-chip {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(58, 74, 63, 0.08);
}

.rain-source-chip text {
  font-size: 22rpx;
  color: #5A6A5F;
}

.rain-source-chip.active {
  background: #D4B896;
  border-color: #D4B896;
}

.rain-source-chip.active text {
  color: #FFFFFF;
}

.immersive-hint {
  position: fixed;
  bottom: 160rpx;
  left: 0;
  right: 0;
  text-align: center;
  animation: fadeInHint 1s ease 1s both;
}
