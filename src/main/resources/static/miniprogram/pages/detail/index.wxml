<view class="detail-page {{immersiveMode ? 'immersive' : ''}}">
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="poem-section fade-in" wx:if="{{poem}}" bindtap="toggleImmersive">
    <view class="chinese-toggle" catchtap="toggleChinese" wx:if="{{!immersiveMode}}">
      <text class="toggle-text">{{useTraditional ? '繁' : '简'}}</text>
    </view>
    <text class="poem-eyebrow">{{immersiveMode ? '沉浸阅读' : '今日诗页'}}</text>
    <text class="poem-title" bindlongpress="onLongPressTitle">{{poem.title}}</text>
    <text class="poem-meta" bindlongpress="onLongPressAuthor">{{poem.dynasty}} · {{poem.author}}</text>
    <view class="poem-divider"></view>
    <text class="poem-tip" wx:if="{{!immersiveMode}}">长按可复制、摘录，点正文进入沉浸阅读</text>
    <view class="poem-body">
      <block wx:for="{{contentLines}}" wx:for-item="item" wx:for-index="index" wx:key="index">
        <text class="poem-line {{item.isFavorite ? 'sentence-favorited' : ''}}" bindlongpress="onLongPressLine" data-line="{{item.text}}" data-index="{{index}}">{{item.text}}</text>
      </block>
    </view>
  </view>

  <view class="author-section" wx:if="{{authorInfo && authorInfo.description && !immersiveMode}}" catchtap="toggleAuthorBio">
    <text class="section-kicker">作者简介</text>
    <view class="author-header">
      <text class="author-name">{{authorInfo.name}}</text>
      <text class="author-arrow">{{showAuthorBio ? '收起' : '展开'}}</text>
    </view>
    <view class="author-bio {{showAuthorBio ? 'expanded' : ''}}">
      <text class="author-bio-text">{{authorInfo.description}}</text>
    </view>
  </view>

  <view class="tags-section" wx:if="{{tagsList.length > 0 && !immersiveMode}}">
    <scroll-view scroll-x class="tags-scroll">
      <view class="tags-inner">
        <text class="tag-capsule" wx:for="{{tagsList}}" wx:key="index" bindtap="onTagTap" data-tag="{{item}}">{{item}}</text>
      </view>
    </scroll-view>
  </view>

  <view class="tab-section" wx:if="{{poem && !immersiveMode && (poem.annotation || poem.appreciation || poem.translation)}}">
    <text class="section-kicker">内容解读</text>
    <view class="tab-bar">
      <view class="tab-item {{activeTab === 'annotation' ? 'active' : ''}}" bindtap="switchTab" data-tab="annotation" wx:if="{{poem.annotation}}">
        <text>注释</text>
      </view>
      <view class="tab-item {{activeTab === 'appreciation' ? 'active' : ''}}" bindtap="switchTab" data-tab="appreciation" wx:if="{{poem.appreciation}}">
        <text>赏析</text>
      </view>
      <view class="tab-item {{activeTab === 'translation' ? 'active' : ''}}" bindtap="switchTab" data-tab="translation" wx:if="{{poem.translation}}">
        <text>译文</text>
      </view>
    </view>

    <view class="tab-content">
      <view class="tab-panel" wx:if="{{activeTab === 'annotation' && poem.annotation}}">
        <block wx:if="{{annotationList.length > 0}}">
          <view class="annotation-item" wx:for="{{annotationList}}" wx:key="index">
            <text class="annotation-word">{{item.word}}</text>
            <text class="annotation-meaning">{{item.meaning}}</text>
          </view>
        </block>
        <text class="tab-text" wx:else>{{poem.annotation}}</text>
      </view>
      <view class="tab-panel" wx:if="{{activeTab === 'appreciation' && poem.appreciation}}">
        <text class="tab-text">{{poem.appreciation}}</text>
      </view>
      <view class="tab-panel" wx:if="{{activeTab === 'translation' && poem.translation}}">
        <text class="tab-text">{{poem.translation}}</text>
      </view>
    </view>
  </view>

  <view class="bottom-bar" wx:if="{{poem && !immersiveMode}}">
    <view class="bottom-btn rain-btn {{rainEnabled ? 'active' : ''}}" bindtap="toggleRain">
      <text class="btn-main">{{rainEnabled ? (rainPlaying ? '收起雨声' : '雨声开启') : '檐下雨'}}</text>
      <text class="btn-sub">{{rainEnabled ? '停风听雨' : '沉浸阅读'}}</text>
    </view>
    <view class="bottom-btn favorite-btn {{isFavoriteFull ? 'active' : ''}}" bindtap="toggleFullFavorite">
      <text class="btn-main">{{isFavoriteFull ? '已收藏' : '收藏全文'}}</text>
      <text class="btn-sub">{{isFavoriteFull ? '已入书签' : '收入书签'}}</text>
    </view>
    <view class="bottom-btn generate-btn" bindtap="goToShare">
      <text class="btn-main">生成卡片</text>
      <text class="btn-sub">今日诗历</text>
    </view>
    <view class="bottom-btn share-btn">
      <text class="btn-main">分享好友</text>
      <text class="btn-sub">传递一首</text>
      <button class="share-trigger" open-type="share"></button>
    </view>
  </view>

  <view class="rain-panel" wx:if="{{poem && immersiveMode}}">
    <view class="rain-switch-card {{rainEnabled ? 'active' : ''}}">
      <view class="rain-switch-meta">
        <text class="rain-title">檐下雨</text>
        <text class="rain-subtitle">{{rainPlaying ? '雨声渐起' : (rainLoading ? '准备中...' : '开关雨声')}}</text>
      </view>
      <switch class="rain-switch" color="#5A6A5F" checked="{{rainEnabled}}" bindchange="onRainSwitchChange" />
    </view>
    <text class="rain-switch-tip">开即落雨，关即收声</text>
    <scroll-view scroll-x class="rain-source-scroll">
      <view class="rain-source-list">
        <view class="rain-source-chip {{rainSourceIndex === index ? 'active' : ''}}"
              wx:for="{{rainSources}}" wx:key="index"
              bindtap="selectRainSource" data-index="{{index}}">
          <text>{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="immersive-hint" wx:if="{{immersiveMode}}">
    <text>沉浸模式已开启，点正文可退出</text>
  </view>

  <view class="pinyin-overlay" wx:if="{{showPinyinModal}}" catchtap="closePinyinModal">
    <view class="pinyin-modal" catchtap="noop">
      <view class="pinyin-loading" wx:if="{{pinyinLoading}}">
        <text>正在获取拼音...</text>
      </view>
      <view class="pinyin-grid" wx:if="{{pinyinData && pinyinData.chars}}">
        <view class="pinyin-char-group" wx:for="{{pinyinData.chars}}" wx:key="index">
          <text class="pinyin-text" wx:if="{{item.pinyin}}">{{item.pinyin}}</text>
          <view class="pinyin-placeholder" wx:else></view>
          <text class="pinyin-char">{{item.ch}}</text>
        </view>
      </view>
      <view class="pinyin-grid" wx:if="{{pinyinError}}">
        <view class="pinyin-char-group" wx:for="{{longPressText.split('')}}" wx:key="index">
          <view class="pinyin-placeholder"></view>
          <text class="pinyin-char">{{item}}</text>
        </view>
      </view>
      <view class="pinyin-loading" wx:if="{{pinyinError}}">
        <text>拼音暂不可用</text>
      </view>
      <view class="pinyin-actions">
        <view class="pinyin-copy-btn" bindtap="copyText">
          <text>复制</text>
        </view>
        <view class="pinyin-copy-btn rhyme-btn" wx:if="{{longPressType === 'sentence' || longPressType === 'text'}}" bindtap="lookupRhyme">
          <text>韵部</text>
        </view>
        <view class="pinyin-fav-btn excerpt-btn" wx:if="{{longPressType === 'sentence'}}" bindtap="openExcerptModal">
          <text>摘录</text>
        </view>
        <view class="pinyin-close-btn" bindtap="closePinyinModal">
          <text>关闭</text>
        </view>
      </view>
    </view>
  </view>

  <view class="excerpt-overlay" wx:if="{{showExcerptModal}}" catchtap="closeExcerptModal">
    <view class="excerpt-modal" catchtap="noop">
      <text class="excerpt-title">摘录本</text>
      <text class="excerpt-sentence">{{longPressText}}</text>
      <textarea
        class="excerpt-note-input"
        placeholder="可选，写一句私人批注"
        maxlength="140"
        value="{{excerptNote}}"
        bindinput="onExcerptNoteInput"
      />
      <view class="excerpt-actions">
        <view class="excerpt-cancel" bindtap="closeExcerptModal">
          <text>取消</text>
        </view>
        <view class="excerpt-save" bindtap="saveExcerpt">
          <text>{{excerptSaving ? '保存中...' : '保存摘录'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="excerpt-overlay" wx:if="{{showRhymeModal}}" catchtap="closePinyinModal">
    <view class="excerpt-modal" catchtap="noop">
      <text class="excerpt-title">韵部</text>
      <text class="excerpt-sentence">{{rhymeData.targetChar}} · {{rhymeData.pinyin}}</text>
      <view class="rhyme-card" wx:if="{{rhymeLoading}}">
        <text>查询中...</text>
      </view>
      <view class="rhyme-card" wx:if="{{rhymeData && !rhymeLoading}}">
        <text class="rhyme-line">{{rhymeData.pingshui}}</text>
        <text class="rhyme-line">{{rhymeData.cilin}}</text>
        <text class="rhyme-note">{{rhymeData.note}}</text>
      </view>
      <view class="excerpt-actions">
        <view class="excerpt-save" bindtap="closePinyinModal">
          <text>知道了</text>
        </view>
      </view>
    </view>
  </view>
</view>

