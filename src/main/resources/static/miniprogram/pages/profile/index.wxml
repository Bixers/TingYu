<!-- pages/profile/index.wxml -->
<view class="profile-page">

  <!-- 已登录：用户信息卡片 -->
  <view class="user-card card fade-in" wx:if="{{isLoggedIn}}">
    <view class="user-info">
      <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/profile_normal.png'}}" mode="aspectFill"></image>
      <view class="user-detail">
        <text class="user-nickname">{{userInfo.nickname}}</text>
        <text class="user-id text-muted">已登录</text>
      </view>
    </view>
  </view>

  <!-- 未登录：引导登录卡片 -->
  <view class="login-card card fade-in" wx:if="{{!isLoggedIn && !showLoginPopup}}">
    <view class="login-guide">
      <text class="login-title">登录后体验更多功能</text>
      <text class="login-desc text-muted">授权微信昵称和头像，即可完成登录</text>
      <view class="btn-primary login-btn" bindtap="showLogin">立即登录</view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section card fade-in" wx:if="{{isLoggedIn}}">
    <view class="menu-item" bindtap="editProfile">
      <text class="menu-text">修改资料</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section fade-in" wx:if="{{isLoggedIn}}">
    <view class="btn-secondary logout-btn" bindtap="logout">退出登录</view>
  </view>

  <!-- 登录弹窗 -->
  <view class="login-mask" wx:if="{{showLoginPopup}}" bindtap="hideLogin">
    <view class="login-popup" catchtap="">
      <text class="popup-title">完善个人信息</text>
      <text class="popup-desc text-muted">请选择头像并输入昵称</text>

      <!-- 头像选择 -->
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar-preview"
               src="{{tempAvatarUrl || '/images/profile_normal.png'}}"
               mode="aspectFill"></image>
        <text class="avatar-hint text-muted">点击选择头像</text>
      </button>

      <!-- 昵称输入 -->
      <view class="nickname-wrap">
        <input class="nickname-input"
               type="nickname"
               placeholder="请输入昵称"
               value="{{tempNickname}}"
               bindinput="onNicknameInput" />
      </view>

      <!-- 操作按钮 -->
      <view class="popup-actions">
        <view class="btn-secondary popup-cancel" bindtap="hideLogin">取消</view>
        <view class="btn-primary popup-confirm {{submitting ? 'disabled' : ''}}" bindtap="confirmLogin">
          {{submitting ? '提交中...' : '确认登录'}}
        </view>
      </view>
    </view>
  </view>

</view>
