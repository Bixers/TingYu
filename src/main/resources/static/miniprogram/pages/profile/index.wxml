<view class="profile-page">
  <view class="user-card card fade-in" wx:if="{{isLoggedIn}}">
    <view class="user-info">
      <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/icon.png'}}" mode="aspectFill"></image>
      <view class="user-detail">
        <text class="user-nickname">{{userInfo.nickname}}</text>
      </view>
    </view>
  </view>

  <view class="login-card card fade-in" wx:if="{{!isLoggedIn}}">
    <view class="login-guide">
      <text class="login-title">微信登录</text>
      <text class="login-desc text-muted">点击后直接完成登录，系统会自动生成固定昵称与头像。</text>
      <button class="btn-primary login-btn" bindtap="requestUserProfile" loading="{{submitting}}" disabled="{{submitting}}">
        {{submitting ? '登录中...' : '微信登录'}}
      </button>
    </view>
  </view>

  <view class="menu-section card fade-in" wx:if="{{isLoggedIn}}">
    <view class="menu-item" bindtap="goToFavorites">
      <text class="menu-text">收藏</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToExcerpts">
      <text class="menu-text">摘录本</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="push-card card fade-in" wx:if="{{isLoggedIn}}">
    <view class="row-between">
      <text class="push-title">每日雨丝</text>
      <switch checked="{{rainPushEnabled}}" bindchange="onRainPushChange" color="#55655C"></switch>
    </view>
    <text class="push-copy">开启后将记录你的订阅偏好，后续会按日发送一条诗意提醒。</text>
    <view class="push-actions">
      <view class="btn-secondary push-btn" bindtap="subscribeDailyRain">
        <text>订阅今日雨丝</text>
      </view>
    </view>
  </view>

  <view class="summary-card card fade-in" wx:if="{{isLoggedIn && usageSummary}}">
    <text class="summary-title">阅读足迹</text>
    <text class="summary-copy">你已在阅读之路上行过 {{usageSummary.daysElapsed || 0}} 日，共读 {{usageSummary.totalPoems || 0}} 首诗词。</text>
    <view class="summary-stats">
      <view class="summary-stat">
        <text class="summary-stat-value">{{usageSummary.totalViews || 0}}</text>
        <text class="summary-stat-label">浏览次数</text>
      </view>
      <view class="summary-stat">
        <text class="summary-stat-value">{{usageSummary.series[6] ? usageSummary.series[6].poems : 0}}</text>
        <text class="summary-stat-label">今日读诗</text>
      </view>
      <view class="summary-stat">
        <text class="summary-stat-value">{{usageSummary.totalSearches || 0}}</text>
        <text class="summary-stat-label">搜索次数</text>
      </view>
    </view>

    <view class="summary-chart">
      <view class="summary-chart-header">
        <text class="summary-chart-title">最近七日阅读轨迹</text>
        <text class="summary-chart-hint">记录停泊过的每一次阅读</text>
      </view>
      <view class="summary-chart-bars">
        <view class="summary-chart-item" wx:for="{{usageSummary.series}}" wx:key="dayKey">
          <view class="summary-chart-track">
            <view class="summary-chart-fill" style="height: {{item.viewsBarHeight}}%;"></view>
          </view>
          <text class="summary-chart-value">{{item.views}}</text>
          <text class="summary-chart-label">{{item.shortDayLabel}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="logout-section fade-in" wx:if="{{isLoggedIn}}">
    <view class="btn-secondary logout-btn" bindtap="logout">退出登录</view>
  </view>
</view>
