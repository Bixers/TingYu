.profile-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.user-card {
  padding: 40rpx 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar,
.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #F5F3F0;
  flex-shrink: 0;
}

.avatar-preview {
  width: 144rpx;
  height: 144rpx;
  border: 4rpx dashed #D9C9B3;
}

.user-detail {
  margin-left: 28rpx;
  display: flex;
  flex-direction: column;
}

.user-nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #3A4A3F;
}

.login-card {
  padding: 60rpx 32rpx;
}

.login-guide {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #3A4A3F;
  text-align: center;
}

.login-desc {
  font-size: 26rpx;
  margin-top: 12rpx;
  text-align: center;
}

.login-btn {
  margin-top: 32rpx;
  width: 100%;
  line-height: 88rpx;
  border: none;
}

.login-btn::after {
  display: none;
}

.menu-section {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0EDE8;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  font-size: 30rpx;
  color: #3A4A3F;
}

.menu-arrow {
  font-size: 28rpx;
  color: #9AA59F;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.push-card,
.summary-card {
  padding: 22rpx 24rpx;
}

.push-card {
  background: linear-gradient(135deg, #3A4A3F 0%, #5A6A5F 100%);
  color: #FFFFFF;
  overflow: hidden;
}

.push-title,
.summary-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.push-copy,
.summary-copy {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.45;
}

.push-copy {
  color: rgba(255, 255, 255, 0.88);
}

.push-actions {
  margin-top: 14rpx;
  display: flex;
  justify-content: center;
}

.push-btn {
  width: 72%;
  text-align: center;
  line-height: 72rpx;
  border-radius: 999rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.summary-card {
  background: linear-gradient(160deg, #F8F4EC 0%, #EFE6D8 100%);
  color: #3A4A3F;
  overflow: hidden;
}

.summary-copy {
  color: #66746B;
}

.summary-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.summary-stat {
  flex: 1;
  background: rgba(58, 74, 63, 0.08);
  border-radius: 18rpx;
  padding: 18rpx 0;
  text-align: center;
}

.summary-stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #3A4A3F;
}

.summary-stat-label {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #7A8A7F;
}

.summary-chart {
  margin-top: 24rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(58, 74, 63, 0.10);
}

.summary-chart-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.summary-chart-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #4F5D55;
}

.summary-chart-hint {
  font-size: 20rpx;
  color: #7A8A7F;
}

.summary-chart-bars {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  min-height: 150rpx;
}

.summary-chart-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.summary-chart-track {
  width: 100%;
  height: 108rpx;
  border-radius: 18rpx;
  background: rgba(58, 74, 63, 0.08);
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

.summary-chart-fill {
  width: 100%;
  min-height: 12rpx;
  border-radius: 18rpx 18rpx 0 0;
  background: linear-gradient(180deg, #5A6A5F 0%, #D4B896 100%);
}

.summary-chart-value {
  font-size: 22rpx;
  font-weight: 600;
  color: #3A4A3F;
}

.summary-chart-label {
  font-size: 18rpx;
  color: #7A8A7F;
}

.logout-section {
  margin-top: 16rpx;
  display: flex;
  justify-content: center;
}

.logout-btn {
  width: 100%;
  text-align: center;
  color: #C0694A;
  border-color: #E8D5CC;
}
