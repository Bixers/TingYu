.profile-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.user-card {
  padding: 40rpx 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar,
.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #F5F3F0;
  flex-shrink: 0;
}

.avatar-preview {
  width: 144rpx;
  height: 144rpx;
  border: 4rpx dashed #D9C9B3;
}

.user-detail {
  margin-left: 28rpx;
  display: flex;
  flex-direction: column;
}

.user-nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #3A4A3F;
}

.user-id {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.login-card {
  padding: 60rpx 32rpx;
}

.login-guide {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.form-guide {
  align-items: stretch;
}

.login-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #3A4A3F;
  text-align: center;
}

.login-desc {
  font-size: 26rpx;
  margin-top: 12rpx;
  text-align: center;
}

.login-btn,
.secondary-btn {
  margin-top: 32rpx;
  width: 100%;
  line-height: 88rpx;
  border: none;
}

.login-btn::after,
.secondary-btn::after,
.avatar-picker::after {
  display: none;
}

.avatar-picker {
  margin-top: 40rpx;
  padding: 24rpx;
  border: none;
  background: #F9F6F1;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-tip {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #7A8A7F;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: #F9F6F1;
  color: #3A4A3F;
  font-size: 30rpx;
}

.menu-section {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0EDE8;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  font-size: 30rpx;
  color: #3A4A3F;
}

.menu-arrow {
  font-size: 28rpx;
  color: #9AA59F;
}

.logout-section {
  margin-top: 40rpx;
  display: flex;
  justify-content: center;
}

.logout-btn {
  width: 100%;
  text-align: center;
  color: #C0694A;
  border-color: #E8D5CC;
}
