<view class="index-page">
  <view class="header">
    <text class="header-title">听雨眠舟</text>
    <text class="header-subtitle">春水碧于天，画船听雨眠</text>
  </view>

  <view class="poem-card-container">
    <view class="poem-card {{animating ? 'fade-in' : ''}}" bindtap="goToDetail">
      <view class="poem-content">
        <text class="poem-title">{{currentPoem.title || '加载中...'}}</text>
        <text class="poem-meta" wx:if="{{currentPoem}}">
          {{currentPoem.dynasty}} · {{currentPoem.author}}
        </text>
        <view class="poem-lines" wx:if="{{contentLines.length > 0}}">
          <block wx:for="{{contentLines}}" wx:key="index">
            <text class="poem-line">{{item}}</text>
          </block>
        </view>
      </view>
    </view>
  </view>

  <view class="action-buttons">
    <view class="action-button" bindtap="loadRandomPoem">
      <text class="button-text">换一首</text>
    </view>
    <view class="action-button" bindtap="goToShare">
      <text class="button-text">生成卡片</text>
    </view>
    <view class="action-button" bindtap="goToDiscover">
      <text class="button-text">发现</text>
    </view>
  </view>

  <view class="loading-overlay" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
