.index-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5F3F0 0%, #E8E4DF 100%);
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.header {
  text-align: center;
  padding: 60rpx 0;
  position: relative;
}

.header-title {
  font-size: 64rpx;
  font-weight: 600;
  color: #3A4A3F;
  letter-spacing: 8rpx;
  display: block;
  margin-bottom: 16rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: #7A8A7F;
  letter-spacing: 4rpx;
}

.chinese-toggle {
  position: absolute;
  right: 0;
  top: 60rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(58, 74, 63, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.chinese-toggle:active {
  background: rgba(58, 74, 63, 0.15);
}

.toggle-text {
  font-size: 28rpx;
  color: #3A4A3F;
  font-weight: 500;
}

.poem-card-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}

.poem-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(58, 74, 63, 0.08);
  padding: 64rpx 48rpx;
}

.poem-content {
  text-align: center;
}

.poem-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #3A4A3F;
  margin-bottom: 24rpx;
  display: block;
}

.poem-meta {
  font-size: 28rpx;
  color: #7A8A7F;
  margin-bottom: 48rpx;
  display: block;
}

.poem-lines {
  margin-top: 40rpx;
}

.poem-line {
  font-size: 36rpx;
  color: #3A4A3F;
  line-height: 2;
  display: block;
  letter-spacing: 4rpx;
}

.action-buttons {
  display: flex;
  justify-content: space-around;
  padding: 60rpx 20rpx 80rpx;
  gap: 32rpx;
}

.action-button {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(58, 74, 63, 0.06);
}

.action-button:active {
  opacity: 0.8;
}

.button-text {
  font-size: 26rpx;
  color: #3A4A3F;
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(245, 243, 240, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-text {
  font-size: 32rpx;
  color: #7A8A7F;
}
