.share-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5F3F0 0%, #EEE7DE 100%);
  display: flex;
  flex-direction: column;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero-section {
  padding: 34rpx 32rpx 10rpx;
}

.page-title {
  display: block;
  font-size: 38rpx;
  font-weight: 600;
  color: #3A4A3F;
}

.page-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #7A8A7F;
}

.preview-panel {
  margin: 20rpx 32rpx 0;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 16rpx 40rpx rgba(58, 74, 63, 0.08);
}

.canvas-container {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  position: relative;
}

.canvas-wrap {
  width: 100%;
  height: 750rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: inset 0 0 0 1rpx rgba(58, 74, 63, 0.06);
  background: rgba(255, 255, 255, 0.66);
}

.share-canvas {
  width: 100%;
  height: 100%;
}

.canvas-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.template-section {
  padding: 28rpx 32rpx 18rpx;
}

.section-title {
  font-size: 26rpx;
  color: #7A8A7F;
  margin-bottom: 20rpx;
  display: block;
}

.template-scroll {
  white-space: nowrap;
}

.template-list {
  display: inline-flex;
  gap: 24rpx;
  padding-bottom: 8rpx;
}

.template-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.template-color {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  transition: border-color 0.2s ease;
}

.template-item.active .template-color {
  border-color: #D4B896;
}

.template-preview-text {
  font-size: 32rpx;
  font-weight: 600;
}

.template-name {
  font-size: 22rpx;
  color: #7A8A7F;
}

.template-item.active .template-name {
  color: #3A4A3F;
  font-weight: 500;
}

.action-section {
  display: flex;
  gap: 24rpx;
  padding: 14rpx 32rpx 0;
}

.save-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-friend-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: normal;
  margin: 0;
}

.share-friend-btn::after {
  border: none;
}

.calendar-meta {
  display: block;
  font-size: 24rpx;
  color: #A07C4A;
  margin-top: 8rpx;
}

.preview-footer {
  margin-top: 22rpx;
  padding: 18rpx 6rpx 0;
}

.preview-meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.preview-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3A4A3F;
}

.preview-desc {
  font-size: 22rpx;
  color: #A07C4A;
}

.preview-template {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #7A8A7F;
  letter-spacing: 1rpx;
}

.preview-excerpt {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5A6A5F;
  word-break: break-all;
  white-space: normal;
}

.preview-excerpt-calendar {
  line-height: 1.9;
  font-size: 22rpx;
}
