/* pages/share/index.wxss */

.share-page {
  min-height: 100vh;
  background: #F5F3F0;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* Canvas 预览区 */
.canvas-container {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  position: relative;
}

.canvas-wrap {
  width: 560rpx;
  height: 750rpx; /* fallback，实际由JS动态计算 */
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 48rpx rgba(58, 74, 63, 0.15);
}

.share-canvas {
  width: 100%;
  height: 100%;
}

.canvas-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 模板选择区 */
.template-section {
  padding: 0 32rpx 24rpx;
}

.section-title {
  font-size: 26rpx;
  color: #7A8A7F;
  margin-bottom: 20rpx;
  display: block;
}

.template-scroll {
  white-space: nowrap;
}

.template-list {
  display: inline-flex;
  gap: 24rpx;
  padding-bottom: 8rpx;
}

.template-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.template-color {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  transition: border-color 0.2s ease;
}

.template-item.active .template-color {
  border-color: #D4B896;
}

.template-preview-text {
  font-size: 32rpx;
  font-weight: 600;
}

.template-name {
  font-size: 22rpx;
  color: #7A8A7F;
}

.template-item.active .template-name {
  color: #3A4A3F;
  font-weight: 500;
}

/* 操作按钮 */
.action-section {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx;
}

.save-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-friend-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: normal;
  margin: 0;
}

.share-friend-btn::after {
  border: none;
}
