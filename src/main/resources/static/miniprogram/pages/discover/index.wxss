/* pages/discover/index.wxss */

.discover-page {
  min-height: 100vh;
  background: #F5F3F0;
  padding: 24rpx;
  padding-bottom: 40rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(58, 74, 63, 0.06);
}

.search-icon-svg {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #9AA59F;
  border-radius: 50%;
  margin-right: 16rpx;
  position: relative;
  flex-shrink: 0;
}
.search-icon-svg::after {
  content: '';
  position: absolute;
  width: 12rpx;
  height: 4rpx;
  background: #9AA59F;
  border-radius: 2rpx;
  right: -8rpx;
  bottom: -2rpx;
  transform: rotate(45deg);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #3A4A3F;
}

.search-placeholder {
  color: #9AA59F;
}

.filter-toggle {
  padding: 16rpx 28rpx;
  background: #FFFFFF;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #7A8A7F;
  box-shadow: 0 2rpx 12rpx rgba(58, 74, 63, 0.06);
}

.filter-toggle.active {
  background: #3A4A3F;
  color: #FDF8F0;
}

/* 筛选面板 */
.filter-panel {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(58, 74, 63, 0.06);
  animation: fadeIn 0.2s ease-out;
}

.filter-group {
  margin-bottom: 24rpx;
}

.filter-group:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 26rpx;
  color: #7A8A7F;
  margin-bottom: 16rpx;
  display: block;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-chip {
  font-size: 24rpx;
  color: #7A8A7F;
  background: #F5F3F0;
  border-radius: 32rpx;
  padding: 10rpx 24rpx;
  transition: all 0.2s ease;
}

.filter-chip.active {
  background: #3A4A3F;
  color: #FFFFFF;
}

.filter-chip.tag-chip.active {
  background: #D4B896;
  color: #FFFFFF;
}

.clear-filter {
  text-align: center;
  padding: 16rpx;
  font-size: 26rpx;
  color: #D4B896;
  margin-top: 16rpx;
}

/* 结果提示 */
.result-hint {
  font-size: 24rpx;
  color: #9AA59F;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

/* 诗词列表卡片 */
.poem-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.poem-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(58, 74, 63, 0.06);
}

.poem-card:active {
  opacity: 0.85;
}

.poem-card-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.poem-card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #3A4A3F;
  letter-spacing: 2rpx;
}

.poem-card-meta {
  font-size: 24rpx;
  color: #7A8A7F;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.poem-card-preview {
  font-size: 28rpx;
  color: #5A6A5F;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.poem-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

/* 列表底部 */
.list-footer {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
}
