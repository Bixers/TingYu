.boat-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #F5F3F0 0%, #FDF8F0 100%);
}

.header {
  padding: 20rpx 12rpx 18rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #3A4A3F;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7A8A7F;
}

.compose-card,
.receive-card,
.summary-card,
.list-card,
.tabs {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #3A4A3F;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.small-link {
  font-size: 24rpx;
  color: #A07C4A;
}

.compose-textarea,
.reply-textarea {
  width: 100%;
  min-height: 200rpx;
  box-sizing: border-box;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  border: 1rpx solid #E8E4DF;
  font-size: 26rpx;
  color: #3A4A3F;
}

.compose-input {
  width: 100%;
  height: 84rpx;
  margin-top: 18rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #FFFFFF;
  border: 1rpx solid #E8E4DF;
  font-size: 26rpx;
  color: #3A4A3F;
}

.compose-actions,
.receive-actions,
.thread-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.compose-btn,
.outline-btn {
  flex: 1;
  text-align: center;
}

.outline-btn {
  padding: 16rpx 0;
  border-radius: 999rpx;
  background: #FFFFFF;
  border: 1rpx solid #E8E4DF;
}

.outline-btn-disabled {
  opacity: 0.58;
}

.received-content,
.message-content,
.thread-content,
.reply-content,
.summary-content {
  display: block;
  font-size: 30rpx;
  line-height: 1.8;
  color: #5A6A5F;
}

.message-drift {
  display: inline-flex;
  margin-bottom: 10rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(124, 138, 106, 0.12);
  font-size: 20rpx;
  color: #55655C;
}

.received-signature,
.message-signature,
.thread-signature,
.reply-signature,
.summary-signature {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #A07C4A;
}

.received-preview {
  padding: 4rpx 0;
}

.received-meta,
.message-meta,
.thread-info {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #8A968D;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.summary-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.summary-item {
  padding: 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(250, 247, 242, 0.98) 0%, rgba(255, 255, 255, 0.88) 100%);
  box-shadow: 0 8rpx 22rpx rgba(58, 74, 63, 0.06);
  border: 1rpx solid rgba(58, 74, 63, 0.04);
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}

.summary-item-0 {
  transform: translateX(0);
}

.summary-item-1 {
  transform: translateX(8rpx);
}

.summary-item-2 {
  transform: translateX(16rpx);
}

.summary-item:active {
  transform: translateX(0) scale(0.99);
  box-shadow: 0 6rpx 16rpx rgba(58, 74, 63, 0.08);
}

.summary-topline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.summary-time {
  font-size: 20rpx;
  color: #8A968D;
}

.summary-content {
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.72;
}

.summary-item-0 .summary-content,
.summary-item-1 .summary-content,
.summary-item-2 .summary-content {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.message-item {
  padding: 20rpx;
  border-radius: 18rpx;
  background: #FAF7F2;
}

.empty-tip {
  font-size: 24rpx;
  color: #7A8A7F;
  line-height: 1.8;
}

.tabs {
  display: flex;
  gap: 12rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 4rpx;
  padding: 18rpx 0 16rpx;
  border-radius: 999rpx;
  text-align: center;
  color: #7A8A7F;
  background: #F7F4EE;
}

.tab-label {
  font-size: 26rpx;
  line-height: 1;
}

.tab-note {
  font-size: 18rpx;
  line-height: 1;
  opacity: 0.72;
}

.tab-count {
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #55655C;
  font-size: 20rpx;
  line-height: 30rpx;
}

.tab-item.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #7C8A6A 0%, #55655C 100%);
}

.tab-item.active .tab-count {
  background: rgba(255, 255, 255, 0.18);
  color: #FFFFFF;
}

.modal-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(58, 74, 63, 0.35);
  z-index: 99;
}

.modal-panel {
  width: 100%;
  max-height: 88vh;
  box-sizing: border-box;
  padding: 28rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: #FDFBF7;
  overflow-y: auto;
}

.thread-root {
  padding: 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #FAF7F2 0%, #FFFFFF 100%);
  border: 1rpx solid rgba(58, 74, 63, 0.04);
}

.reply-list {
  margin-top: 24rpx;
}

.reply-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #3A4A3F;
}

.reply-item {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  border: 1rpx solid #E8E4DF;
  margin-bottom: 14rpx;
}
