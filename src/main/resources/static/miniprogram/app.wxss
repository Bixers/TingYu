/* 全局样式 */
/* 色彩体系：主色 #3A4A3F(墨绿) 背景 #F5F3F0(米白) 暖背景 #FDF8F0(牙色) 点缀 #D4B896(淡金) */

page {
  background-color: #F5F3F0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #3A4A3F;
}

.container {
  padding: 20rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(58, 74, 63, 0.08);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.text-primary { color: #3A4A3F; }
.text-secondary { color: #7A8A7F; }
.text-muted { color: #9AA59F; }
.text-accent { color: #D4B896; }

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
  color: #9AA59F;
}

/* 淡入动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.fade-in {
  animation: fadeIn 0.4s ease-out;
}

/* 标签胶囊 */
.tag-capsule {
  display: inline-block;
  font-size: 22rpx;
  color: #D4B896;
  background: rgba(212, 184, 150, 0.15);
  border-radius: 32rpx;
  padding: 6rpx 20rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}
.tag-capsule.active {
  background: #D4B896;
  color: #FFFFFF;
}

/* 主按钮 */
.btn-primary {
  background: #3A4A3F;
  color: #FDF8F0;
  border-radius: 40rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  text-align: center;
  border: none;
}
.btn-primary:active {
  opacity: 0.85;
}

/* 次按钮 */
.btn-secondary {
  background: #FFFFFF;
  color: #3A4A3F;
  border: 2rpx solid #E8E4DF;
  border-radius: 40rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  text-align: center;
}
.btn-secondary:active {
  opacity: 0.85;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: #9AA59F;
}
.empty-state .empty-text {
  font-size: 28rpx;
  margin-top: 24rpx;
}

::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}
