/* 全局样式 */
page {
  background-color: #F5F3F0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #3A4A3F;
}

.container {
  padding: 20rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(58, 74, 63, 0.08);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.text-primary { color: #3A4A3F; }
.text-secondary { color: #7A8A7F; }
.text-muted { color: #9AA59F; }

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
  color: #9AA59F;
}

::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}
